# PO Sync Digest — copy to .env and fill in. All tier/config variation lives here, never in code.
APP_NAME=PO Sync Digest
DATABASE_URL=sqlite:///./app.db
HOST_PORT=8000

# Incoming X-API-Key required on protected digest endpoints
DIGEST_API_KEY=

# SOV HTTP API (read-only; used by later specs)
SOV_URL=http://localhost:8765
SOV_API_KEY=
